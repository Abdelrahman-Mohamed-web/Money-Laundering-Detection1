from __future__ import annotations

import argparse
from pathlib import Path

import joblib
import pandas as pd

from src.feature_engineering.transaction_features import build_transaction_features


def predict(input_path: str | Path, model_path: str | Path = "models_saved/aml_model.joblib") -> pd.DataFrame:
    model_file = Path(model_path)
    if not model_file.exists():
        raise FileNotFoundError("Model not found. Run `python -m src.training.train --config config/config.yaml` first.")

    df = pd.read_csv(input_path)
    X, _ = build_transaction_features(df)
    model = joblib.load(model_file)
    output = df.copy()
    output["laundering_probability"] = model.predict_proba(X)[:, 1]
    output["predicted_is_laundering"] = model.predict(X)
    return output


def main() -> None:
    parser = argparse.ArgumentParser(description="Predict money laundering risk for transactions.")
    parser.add_argument("--input", required=True, help="CSV file of transactions.")
    parser.add_argument("--model", default="models_saved/aml_model.joblib", help="Trained model path.")
    parser.add_argument("--output", default="results/predictions.csv", help="Output CSV path.")
    args = parser.parse_args()

    predictions = predict(args.input, args.model)
    output_path = Path(args.output)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    predictions.to_csv(output_path, index=False)
    print(f"Predictions written to {output_path}")


if __name__ == "__main__":
    main()
